{
  "$schema": "https://raw.githubusercontent.com/nicjohnson/hello-tauri/v2/core/tauri-config-schema/schema.json",
  "productName": "NicTasks",
  "version": "0.1.0",
  "identifier": "com.champnic.nictasks",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NicTasks",
        "width": 600,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENEOEM5RjVEN0M4NjFBRjMKUldUekdvWjhYWitNelg2TWd3YkxJcTIzR2UxeGljdGx2MVUwdm1ubWYzVHdBTmY2dGllSnV5OHEK",
      "endpoints": [
        "https://github.com/champnic/NicTasks/releases/latest/download/latest.json"
      ]
    }
  }
}
